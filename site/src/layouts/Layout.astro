---
import '../styles/global.css';

const {
  title = 'Moonsorter',
  description = 'Pairwise ranking for AniList via MoonBit and WASM.',
  'data-base-url': dataBaseUrl = '',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${dataBaseUrl}favicon.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Gloock&family=JetBrains+Mono:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-base-url={dataBaseUrl}>
    <div class="site-container">
      <header class="flex flex-col gap-6 pb-8 pt-8 md:flex-row md:items-center md:justify-between">
        <a href={dataBaseUrl || '/'} class="flex items-center gap-4">
          <div class="moon-mark" aria-hidden="true"></div>
          <h1 class="font-display text-4xl md:text-5xl">Moonsorter</h1>
        </a>
        <nav class="flex flex-wrap items-center gap-2">
          <a class="nav-link" href="https://github.com/brickfrog/moonsorter" rel="noopener">GitHub</a>
        </nav>
      </header>
      <main class="flex flex-col gap-16">
        <slot />
      </main>
      <footer class="site-footer">
        <span>Built with MoonBit + WASM.</span>
        <a href="https://github.com/brickfrog/moonsorter" rel="noopener">source</a>
      </footer>
    </div>
  </body>
</html>
