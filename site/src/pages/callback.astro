---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL;
---
<Layout title="Connecting to AniList" data-base-url={baseUrl}>
  <section class="card">
    <div class="pill">Connecting</div>
    <h3 class="text-xl font-display">Syncing with AniList</h3>
    <p class="text-sm text-latte-subtext1">
      Finishing authorization, then redirecting you.
    </p>
    <p class="text-xs text-latte-subtext0" data-auth-status></p>
  </section>

  <script>
    import { consumeAuthResponse } from '../lib/auth';

    const status = document.querySelector('[data-auth-status]');
    const baseUrl = document.body.dataset.baseUrl || '';

    consumeAuthResponse()
      .then((token) => {
        window.location.replace(baseUrl || '/');
      })
      .catch((error) => {
        if (status) {
          status.textContent =
            error instanceof Error ? error.message : 'Authorization failed.';
        }
      });
  </script>
</Layout>
