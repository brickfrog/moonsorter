---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import rabbit2 from '../../public/rabbit2.png';

const baseUrl = import.meta.env.BASE_URL;
---
<Layout title="Moonsorter" description="Pairwise ranking for AniList, powered by MoonBit and WASM." data-base-url={baseUrl}>
  <section class="grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] lg:items-center">
    <div class="space-y-6">
      <h2 class="text-4xl font-display leading-[1.05] md:text-5xl">
        Rank your anime list with pairwise comparisons.
      </h2>
      <p class="text-lg text-latte-subtext1">
        Pick which item is better until you're satisfied with the order, then export or upload the results.
      </p>
      <div class="flex flex-wrap gap-3">
        <button class="btn btn-anilist" type="button" data-action="connect">
          <img src={`${baseUrl}/anilist-logo.svg`} alt="" class="h-5 w-5" />
          <span>Connect AniList</span>
        </button>
        <a class="btn-secondary" href={`${baseUrl}/rank`}>Open ranking</a>
        <a class="btn-secondary" href={`${baseUrl}/rank?import=csv`}>Upload CSV</a>
      </div>
    </div>
    <div class="card space-y-4">
      <div class="space-y-4">
        <div class="flex items-start gap-3">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-latte-sapphire text-sm font-bold text-white">1</span>
          <div>
            <p class="font-semibold text-latte-text">Import</p>
            <p class="text-sm text-latte-subtext1">Connect AniList or upload a CSV.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-latte-sapphire text-sm font-bold text-white">2</span>
          <div>
            <p class="font-semibold text-latte-text">Filter</p>
            <p class="text-sm text-latte-subtext1">Optionally narrow down by rank or year.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-latte-sapphire text-sm font-bold text-white">3</span>
          <div>
            <p class="font-semibold text-latte-text">Compare</p>
            <p class="text-sm text-latte-subtext1">Pick which item is better.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-latte-sapphire text-sm font-bold text-white">4</span>
          <div>
            <p class="font-semibold text-latte-text">Export</p>
            <p class="text-sm text-latte-subtext1">Upload to AniList or download as CSV/JSON.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="space-y-6">
    <div class="card">
      <div class="flex flex-col gap-6 md:flex-row md:items-start">
        <div class="flex justify-center md:justify-start">
          <Image
            src={rabbit2}
            alt="Rabbit lecturer"
            class="h-40 w-40 rounded-full object-contain md:h-48 md:w-48"
            loading="lazy"
          />
        </div>
        <div class="space-y-4 md:pt-1">
          <h3 class="text-2xl font-display">How it works</h3>
          <p class="text-sm text-latte-subtext1">
            Uses a statistical model to learn your preferences from pairwise comparisons.
            Prioritizes asking about items you're uncertain about, so you don't waste time on obvious choices.
          </p>
          <p class="text-sm text-latte-subtext1">
            If you're rescoring an existing list, your current scores are used as a starting point.
          </p>
          <details class="mt-3 text-xs">
            <summary class="cursor-pointer font-semibold text-latte-subtext0 hover:text-latte-text">Technical details</summary>
            <div class="mt-2 space-y-2 text-sm text-latte-subtext1">
              <p>
                Fits a <strong>Plackett-Luce preference model</strong> using the MM algorithm.
                For rescoring, original scores seed the model as a soft prior (<strong>MAP regularization</strong>).
                Pair selection uses active-learning policies. Uncertainty via <strong>bootstrap resampling</strong>.
                Tier list uses <strong>1D k-means</strong>. Inspired by Gwern's Resorter.
              </p>
            </div>
          </details>
          <div class="flex flex-wrap gap-3 text-xs text-latte-subtext0">
            <a class="underline decoration-latte-sapphire/60 hover:text-latte-text" href="https://gwern.net/resorter">Gwern's Resorter</a>
            <a class="underline decoration-latte-sapphire/60 hover:text-latte-text" href="https://en.wikipedia.org/wiki/Plackett%E2%80%93Luce_model">Plackett-Luce</a>
            <a class="underline decoration-latte-sapphire/60 hover:text-latte-text" href="https://projecteuclid.org/journals/annals-of-statistics/volume-32/issue-1/MM-algorithms-for-generalized-Bradley-Terry-models/10.1214/aos/1079120141.full">MM Algorithm</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { consumeAuthResponse, getToken, login } from '../lib/auth';

    const connectButton = document.querySelector('[data-action="connect"]');

    if (connectButton) {
      connectButton.addEventListener('click', () => {
        try {
          login();
        } catch (error) {
          console.error(error instanceof Error ? error.message : 'Missing client ID.');
        }
      });
    }

    consumeAuthResponse()
      .catch((error) => {
        console.error(error instanceof Error ? error.message : 'Authorization failed.');
      })
      .finally(() => {
        const token = getToken();
        if (token && connectButton) {
          const baseUrl = document.body.dataset.baseUrl || '';
          connectButton.innerHTML = `
            <img src="${baseUrl}/anilist-logo.svg" alt="" class="h-5 w-5" />
            <span>Connected ✓</span>
          `;
          connectButton.classList.add('btn-connected');
          connectButton.setAttribute('disabled', 'true');
        }
      });
  </script>
</Layout>
