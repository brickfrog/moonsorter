---
const { left = 'Item A', right = 'Item B' } = Astro.props;
---
<section class="hidden compare-section" data-step="compare">
  <header class="compare-header">
    <div class="compare-header-left">
      <div class="pill">Step 4: Compare</div>
      <div class="pill compare-strategy hidden" data-pair-strategy></div>
    </div>
    <div class="compare-header-right">
      <span class="compare-progress-text" data-progress-text>0 / 0 comparisons</span>
      <span class="help-dot" title="Estimate based on n·log(n). Actual may vary with active learning.">?</span>
    </div>
  </header>

  <div class="compare-arena" data-compare>
    <button class="compare-card compare-card-a" type="button" data-choice="A">
      <div class="compare-card-top">
        <span class="compare-card-kbd kbd-hint"><span class="compare-card-arrow">→</span> A · press A or ←</span>
        <span class="compare-card-kbd touch-hint hidden">Tap to choose</span>
        <span class="compare-card-seed" data-choice-seed="A"></span>
      </div>
      <div class="compare-card-poster" data-choice-poster="A">
        <img class="compare-card-cover hidden" data-choice-cover="A" alt="" loading="lazy" />
        <span class="compare-card-poster-label">&lt; poster ·<br /><span data-choice-title-label="A">{left}</span> &gt;</span>
      </div>
      <div class="compare-card-foot">
        <strong class="compare-card-title font-display" data-choice-title="A">{left}</strong>
        <div class="compare-card-meta" data-choice-meta="A"></div>
      </div>
      <div class="compare-card-kbd-badges kbd-hint">
        <span class="kbd-badge">A</span><span class="kbd-badge">←</span>
      </div>
    </button>

    <div class="compare-vs">
      <div class="vs-orb">
        <span class="vs-label font-display">vs</span>
      </div>
      <button class="tie-button" type="button" data-choice="TIE">
        <span class="tie-symbol">≈</span>
        <span class="tie-label">Tie / skip</span>
        <span class="kbd-badge kbd-hint">␣</span>
      </button>
    </div>

    <button class="compare-card compare-card-b" type="button" data-choice="B">
      <div class="compare-card-top">
        <span class="compare-card-kbd kbd-hint">B · press B or →</span>
        <span class="compare-card-kbd touch-hint hidden">Tap to choose</span>
        <span class="compare-card-seed" data-choice-seed="B"></span>
      </div>
      <div class="compare-card-poster" data-choice-poster="B">
        <img class="compare-card-cover hidden" data-choice-cover="B" alt="" loading="lazy" />
        <span class="compare-card-poster-label">&lt; poster ·<br /><span data-choice-title-label="B">{right}</span> &gt;</span>
      </div>
      <div class="compare-card-foot">
        <strong class="compare-card-title font-display" data-choice-title="B">{right}</strong>
        <div class="compare-card-meta" data-choice-meta="B"></div>
      </div>
      <div class="compare-card-kbd-badges kbd-hint">
        <span class="kbd-badge">B</span><span class="kbd-badge">→</span>
      </div>
    </button>
  </div>

  <div class="compare-progress-row" data-progress>
    <div class="progress-track">
      <div class="progress-fill" data-progress-fill></div>
    </div>
    <p class="compare-progress-meta" data-progress-meta>
      <span>Estimated total: 0 comparisons</span>
    </p>
  </div>
</section>
