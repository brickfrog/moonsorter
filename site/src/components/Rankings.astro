---
const { title = 'Results' } = Astro.props;
---
<section class="hidden results-section" data-step="results">
  <header class="results-header">
    <div class="pill">Step 5: Results</div>
    <h3 class="results-headline font-display" data-results-headline>{title}</h3>
    <p class="results-subhead">
      CI bars show the 95% bootstrap rank interval. Amber stripe marks an uncertain row — click it to compare next.
    </p>
  </header>

  <div class="results-layout">
    <div class="results-main">
      <div class="results-table-actions">
        <button class="btn-secondary" type="button" data-action="select-all">Select all</button>
        <button class="btn-secondary" type="button" data-action="select-none">Select none</button>
        <span class="status-slot" data-selection-status></span>
      </div>

      <div class="rankings overflow-x-auto" data-rankings>
        <table class="results-table">
          <thead>
            <tr>
              <th class="col-check"></th>
              <th class="col-rank cursor-pointer" data-sort="rank">Rank <span data-sort-indicator="rank"></span></th>
              <th class="col-title cursor-pointer" data-sort="title">Title <span data-sort-indicator="title"></span></th>
              <th class="col-score cursor-pointer" data-sort="originalScore">Original <span data-sort-indicator="originalScore"></span></th>
              <th class="col-score cursor-pointer" data-sort="newScore">New <span data-sort-indicator="newScore"></span></th>
              <th class="col-ci cursor-pointer" data-sort="rankCI">Rank CI · 95% <span data-sort-indicator="rankCI"></span></th>
              <th class="col-topk cursor-pointer" data-sort="topKConfidence">Top-K <span data-sort-indicator="topKConfidence"></span></th>
            </tr>
          </thead>
          <tbody data-rankings-body></tbody>
        </table>
      </div>
    </div>

    <aside class="results-sidebar">
      <div class="sidebar-card" data-analysis-controls>
        <p class="sidebar-eyebrow">Bootstrap analysis</p>
        <p class="sidebar-title font-display">Stability check</p>
        <p class="sidebar-body">Resample comparisons to estimate rank confidence intervals.</p>
        <div class="analysis-controls-stack">
          <label>
            <span class="inline-flex items-center gap-2">Samples <span class="help-dot" title="Bootstrap resamples.">?</span></span>
            <input id="analysis-samples" type="number" min="50" step="50" value="200" />
          </label>
          <label>
            <span class="inline-flex items-center gap-2">Top-K <span class="help-dot" title="Lock-in threshold rank.">?</span></span>
            <input id="analysis-topk" type="number" min="1" step="1" value="10" />
          </label>
          <label>
            <span class="inline-flex items-center gap-2">Max iterations <span class="help-dot" title="MM fit iterations per sample.">?</span></span>
            <input id="analysis-max-iter" type="number" min="5" step="5" value="40" />
          </label>
        </div>
        <button class="btn" type="button" data-action="run-analysis">
          Calculate confidence intervals
        </button>
        <p class="status-slot" data-analysis-status></p>
      </div>

      <div class="sidebar-card hidden" data-analysis-summary>
        <p class="sidebar-eyebrow" data-analysis-eyebrow>Bootstrap · — resamples</p>
        <p class="sidebar-title font-display">Ranking stability</p>
        <p class="sidebar-body">Median rank change under resampling.</p>
        <dl class="stability-stats">
          <div>
            <dt>Median CI width</dt>
            <dd data-analysis-median>—</dd>
          </div>
          <div>
            <dt>Top-K lock-in</dt>
            <dd data-analysis-topk>—</dd>
          </div>
          <div>
            <dt>MM iterations</dt>
            <dd data-stat-iters>—</dd>
          </div>
          <div>
            <dt>Pairs compared</dt>
            <dd data-stat-pairs>—</dd>
          </div>
        </dl>
        <div class="sidebar-callout">
          <span class="sidebar-callout-tag">Recommendation</span>
          <p data-analysis-recommendation>—</p>
        </div>
      </div>

      <div class="sidebar-card hidden" data-uncertain-card>
        <p class="sidebar-eyebrow">Uncertain items</p>
        <p class="sidebar-title font-display">Click to compare</p>
        <div class="analysis-uncertain-list" data-analysis-uncertain-list></div>
        <button class="btn-secondary" type="button" data-action="resume-comparisons">
          Keep comparing uncertain pairs
        </button>
      </div>

      <div class="sidebar-card">
        <p class="sidebar-eyebrow">Export</p>
        <button class="btn hidden" type="button" data-action="upload">
          Push scores to AniList →
        </button>
        <div class="export-rows">
          <button class="export-row" type="button" data-action="download-results">
            <span class="export-label">Rankings</span>
            <span class="export-ext">.json</span>
          </button>
          <button class="export-row" type="button" data-action="download-csv">
            <span class="export-label">Spreadsheet</span>
            <span class="export-ext">.csv</span>
          </button>
          <button class="export-row" type="button" data-action="download-session">
            <span class="export-label">Session state</span>
            <span class="export-ext">.session</span>
          </button>
        </div>
        <button class="btn-secondary" type="button" data-action="restart">
          Start over
        </button>
      </div>
    </aside>
  </div>
</section>
