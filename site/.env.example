# AniList OAuth Client ID (get from https://anilist.co/settings/developer)
PUBLIC_ANILIST_CLIENT_ID=

# OAuth flow: 'token' for static sites (GitHub Pages), 'code' for server deployments
PUBLIC_ANILIST_RESPONSE_TYPE=token

# Redirect URI - update this for your deployment
PUBLIC_ANILIST_REDIRECT_URI=http://localhost:4321/callback
